---
import { routes, site } from "../../../config";

const navigation = [
  {
    label: "Inicio",
    href: routes.home,
  },
  {
    label: "Sobre nosotros",
    href: routes.about,
  },
  {
    label: "Servicios",
    href: routes.services,
  },
  {
    label: "Testimonios",
    href: routes.testimonials,
  },
  {
    label: "Contáctanos",
    href: routes.contact,
  },
];
---

<footer
  class="relative w-full pt-32 pb-16 overflow-hidden bg-primary text-primary-foreground"
  role="contentinfo"
  aria-label="Pie de página de Egida Jurídica"
>
  <!-- Background decorative image -->
  <div
    class="absolute inset-0 z-0 opacity-40 pointer-events-none"
    aria-hidden="true"
  >
    <img
      src="https://images.pexels.com/photos/159720/justice-law-case-hearing-159720.jpeg"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-primary/80"></div>
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 flex flex-col items-center footer-animate"
  >
    <!-- Logo Section -->
    <a
      href="/"
      class="flex flex-col items-center group mb-16"
      aria-label="Egida Jurídica — Ir al inicio"
    >
      <img
        src="/logo_center.png"
        alt="Logotipo de Egida Jurídica"
        class="w-auto h-32 md:h-40 object-contain"
        loading="lazy"
      />
    </a>

    <!-- Navigation Links -->
    <nav
      class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-16 text-base font-sans uppercase font-medium text-primary-foreground/90"
      aria-label="Navegación del pie de página"
    >
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="hover:text-primary-foreground transition-colors"
            aria-label={`Ir a ${item.label}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Top Divider -->
    <div
      class="w-full h-px bg-primary-foreground/10 mb-16"
      role="separator"
      aria-hidden="true"
    >
    </div>

    <!-- Middle Section: Testimonials | Social | Connect -->
    <div
      class="w-full flex flex-col md:flex-row items-center justify-between mb-16 gap-8"
    >
      <!-- Reviews link -->
      <a
        href={site.googleReviews}
        class="font-serif italic text-xl md:text-2xl text-primary-foreground/90 hover:text-primary-foreground transition-colors relative group"
        aria-label="Ver nuestras reseñas en Google"
        target="_blank"
        rel="noopener noreferrer"
      >
        Reseñas
        <span
          class="absolute -bottom-1 left-0 w-full h-px bg-primary-foreground/40 group-hover:bg-primary-foreground transition-colors"
          aria-hidden="true"></span>
      </a>

      <!-- Social Icons -->
      <div
        class="flex items-center gap-4"
        role="list"
        aria-label="Redes sociales"
      >
        <!-- Facebook -->
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="size-11 rounded-full border border-primary-foreground/30 flex items-center justify-center hover:bg-primary-foreground/10 hover:border-primary-foreground transition-all"
          aria-label="Visitar nuestro perfil de Facebook"
          role="listitem"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
            ></path>
          </svg>
        </a>
        <!-- Instagram -->
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="size-11 rounded-full border border-primary-foreground/30 flex items-center justify-center hover:bg-primary-foreground/10 hover:border-primary-foreground transition-all"
          aria-label="Visitar nuestro perfil de Instagram"
          role="listitem"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
        <!-- LinkedIn -->
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="size-11 rounded-full border border-primary-foreground/30 flex items-center justify-center hover:bg-primary-foreground/10 hover:border-primary-foreground transition-all"
          aria-label="Visitar nuestro perfil de LinkedIn"
          role="listitem"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Connect -->
      <a
        href={site.linktree}
        class="font-serif italic text-xl md:text-2xl text-primary-foreground/90 hover:text-primary-foreground transition-colors relative group"
        aria-label="Conecta con nosotros a través de Linktree"
        target="_blank"
        rel="noopener noreferrer"
      >
        Conecta
        <span
          class="absolute -bottom-1 left-0 w-full h-px bg-primary-foreground/40 group-hover:bg-primary-foreground transition-colors"
          aria-hidden="true"></span>
      </a>
    </div>

    <!-- Bottom Divider -->
    <div
      class="w-full h-px bg-primary-foreground/10 mb-12"
      role="separator"
      aria-hidden="true"
    >
    </div>

    <!-- Bottom Section: Addresses & Legal -->
    <div
      class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 text-sm md:text-base font-sans text-primary-foreground/70 leading-relaxed text-center lg:text-left justify-end
      items-end"
    >
      <!-- Column 1: Contact Info -->
      <address class="flex flex-col gap-2 not-italic">
        <p>
          Número de celular: <br />
          <a
            href={`tel:${site.phone}`}
            class="text-primary-foreground hover:underline transition-colors"
            aria-label={`Llamar al ${site.phone}`}>{site.phone}</a
          >
        </p>
        <p>
          Correo electrónico: <a
            href={`mailto:${site.email}`}
            class="text-primary-foreground hover:underline transition-colors"
            aria-label={`Enviar correo a ${site.email}`}>{site.email}</a
          >
        </p>
        <p class="mt-1">{site.address}</p>
      </address>

      <!-- Column 2: Empty -->
      <div class="flex flex-col justify-center text-center"></div>

      <!-- Column 3: Legal Links -->
      <div class="flex flex-col items-center lg:items-end justify-center gap-4">
        <nav
          class="flex items-center gap-3 text-[0.65rem] md:text-xs"
          aria-label="Enlaces legales"
        >
          <a
            href={routes.privacy}
            class="hover:text-primary-foreground transition-colors"
            aria-label="Leer nuestra política de privacidad"
            >Política de privacidad</a
          >
          <a
            href={routes.terms}
            class="hover:text-primary-foreground transition-colors"
            aria-label="Leer nuestros términos y condiciones"
            >Términos y condiciones</a
          >
        </nav>
      </div>
    </div>
  </div>
</footer>
