---
import { routes, site } from "../../../config";

const navLinks = [
  {
    label: "Inicio",
    href: routes.home,
    ariaLabel: "Ir a la página de inicio",
  },
  {
    label: "Acerca",
    href: routes.about,
    ariaLabel: "Ir a la página sobre nosotros",
  },
  {
    label: "Servicios",
    href: routes.services,
    ariaLabel: "Ir a la página de servicios jurídicos",
  },
  {
    label: "Testimonios",
    href: routes.testimonials,
    ariaLabel: "Ir a la página de testimonios de clientes",
  },
  {
    label: "Contáctanos",
    href: routes.contact,
    ariaLabel: "Ir a la página de contacto",
  },
];
---

<header
  class="absolute top-0 left-0 w-full z-50 px-6 md:px-12 py-6 flex items-start justify-between text-primary-foreground font-sans text-sm gap-8"
  role="banner"
>
  <!-- Left section: Main Navigation (desktop) -->
  <nav
    class="hidden md:flex items-center gap-8 mt-2"
    aria-label="Navegación principal"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="flex items-center gap-2 hover:text-primary-foreground/80 transition font-medium"
          aria-label={link.ariaLabel}
        >
          <span class="text-base">{link.label}</span>
        </a>
      ))
    }
  </nav>

  <!-- Center section: Logo -->
  <a
    href="/"
    class="flex flex-col items-center group"
    aria-label="Egida Jurídica — Ir a la página de inicio"
  >
    <img
      src="/logo.png"
      alt="Logotipo de Egida Jurídica"
      class="w-auto h-12 object-contain"
    />
  </a>

  <!-- Right section: Contact info (desktop) -->
  <div
    class="hidden xl:flex items-center gap-8 mt-2"
    aria-label="Información de contacto"
  >
    <a
      href={`tel:${site.phone}`}
      class="flex items-center gap-2 hover:text-primary-foreground/80 transition"
      aria-label={`Llamar al número ${site.phone}`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6 text-primary-foreground/70"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M10.5 18.75a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z"
        ></path>
        <path
          fill-rule="evenodd"
          d="M8.625.75A3.375 3.375 0 0 0 5.25 4.125v15.75a3.375 3.375 0 0 0 3.375 3.375h6.75a3.375 3.375 0 0 0 3.375-3.375V4.125A3.375 3.375 0 0 0 15.375.75h-6.75ZM7.5 4.125C7.5 3.504 8.004 3 8.625 3H9.75v.375c0 .621.504 1.125 1.125 1.125h2.25c.621 0 1.125-.504 1.125-1.125V3h1.125c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-6.75A1.125 1.125 0 0 1 7.5 19.875V4.125Z"
          clip-rule="evenodd"></path>
      </svg>

      <span class="text-base">{site.phone}</span>
    </a>
    <a
      href="#"
      class="flex items-center gap-2 hover:text-primary-foreground/80 transition font-medium"
      aria-label={`Dirección: ${site.address}`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6 text-primary-foreground/70"
        aria-hidden="true"
        focusable="false"
      >
        <path
          fill-rule="evenodd"
          d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
          clip-rule="evenodd"></path>
      </svg>

      <span class="text-base">{site.address}</span>
    </a>
  </div>

  <!-- Mobile: Hamburger Button -->
  <button
    id="mobile-menu-toggle"
    class="md:hidden flex flex-col justify-center items-center w-10 h-10 mt-1 relative z-60 cursor-pointer"
    aria-label="Abrir menú de navegación"
    aria-expanded="false"
    aria-controls="mobile-menu"
    type="button"
  >
    <span class="hamburger-line hamburger-line-1"></span>
    <span class="hamburger-line hamburger-line-2"></span>
    <span class="hamburger-line hamburger-line-3"></span>
  </button>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-55 pointer-events-none invisible [&.is-open]:pointer-events-auto [&.is-open]:visible"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación móvil"
>
  <!-- Backdrop -->
  <div
    class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-400 ease-in-out [.is-open>&]:opacity-100"
  >
  </div>

  <!-- Panel -->
  <div
    class="absolute top-0 left-0 w-[85%] max-w-95 h-full bg-primary text-primary-foreground flex flex-col py-8 px-4 overflow-y-auto overflow-x-hidden -translate-x-full transition-transform duration-450 ease-[cubic-bezier(0.77,0,0.175,1)] shadow-[4px_0_30px_rgba(0,0,0,0.3)] [.is-open>&]:translate-x-0"
  >
    <!-- Close button -->
    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 text-primary-foreground opacity-60 cursor-pointer bg-transparent border-none p-1 transition-all duration-200 ease-in-out hover:opacity-100 hover:rotate-90"
      aria-label="Cerrar menú de navegación"
      type="button"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-6"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Mobile Nav Links -->
    <nav class="flex flex-col mt-8" aria-label="Navegación principal móvil">
      {
        navLinks.map((link, i) => (
          <a
            href={link.href}
            class="mobile-menu-link flex items-center justify-between py-1 text-primary-foreground no-underline opacity-0 hover:text-gold transition-colors duration-200"
            aria-label={link.ariaLabel}
            style={`--delay: ${i * 0.07}s`}
          >
            <span class="text-base font-medium tracking-tight">
              {link.label}
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5 opacity-40"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        ))
      }
    </nav>

    <!-- Divider -->
    <div class="h-px bg-primary-foreground/10 my-6"></div>

    <!-- Mobile Contact Info -->
    <div class="flex flex-col gap-4">
      <a
        href={`tel:${site.phone}`}
        class="flex items-center gap-3 text-primary-foreground opacity-75 no-underline text-sm font-sans transition-all duration-200 hover:opacity-100 hover:text-gold"
        aria-label={`Llamar al número ${site.phone}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-5 text-gold shrink-0"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M10.5 18.75a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z"
          ></path>
          <path
            fill-rule="evenodd"
            d="M8.625.75A3.375 3.375 0 0 0 5.25 4.125v15.75a3.375 3.375 0 0 0 3.375 3.375h6.75a3.375 3.375 0 0 0 3.375-3.375V4.125A3.375 3.375 0 0 0 15.375.75h-6.75ZM7.5 4.125C7.5 3.504 8.004 3 8.625 3H9.75v.375c0 .621.504 1.125 1.125 1.125h2.25c.621 0 1.125-.504 1.125-1.125V3h1.125c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-6.75A1.125 1.125 0 0 1 7.5 19.875V4.125Z"
            clip-rule="evenodd"></path>
        </svg>
        <span>{site.phone}</span>
      </a>
      <a
        href={`mailto:${site.email}`}
        class="flex items-center gap-3 text-primary-foreground opacity-75 no-underline text-sm font-sans transition-all duration-200 hover:opacity-100 hover:text-gold"
        aria-label={`Enviar correo a ${site.email}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-5 text-gold shrink-0"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z"
          ></path>
          <path
            d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z"
          ></path>
        </svg>
        <span>{site.email}</span>
      </a>
      <a
        href="#"
        class="flex items-center gap-3 text-primary-foreground opacity-75 no-underline text-sm font-sans transition-all duration-200 hover:opacity-100 hover:text-gold"
        aria-label={`Dirección: ${site.address}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-5 text-gold shrink-0"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill-rule="evenodd"
            d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
            clip-rule="evenodd"></path>
        </svg>
        <span>{site.address}</span>
      </a>
    </div>

    <!-- Social links -->
    <div class="flex gap-5 mt-auto pt-8">
      <a
        href={site.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="flex items-center justify-center w-10 h-10 rounded-full border border-white/15 text-primary-foreground opacity-70 transition-all duration-200 hover:opacity-100 hover:bg-white/8 hover:border-gold hover:-translate-y-0.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-3"
        >
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
          ></path>
        </svg>
      </a>
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="flex items-center justify-center w-10 h-10 rounded-full border border-white/15 text-primary-foreground opacity-70 transition-all duration-200 hover:opacity-100 hover:bg-white/8 hover:border-gold hover:-translate-y-0.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-3"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
      <a
        href={site.youtube}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
        class="flex items-center justify-center w-10 h-10 rounded-full border border-white/15 text-primary-foreground opacity-70 transition-all duration-200 hover:opacity-100 hover:bg-white/8 hover:border-gold hover:-translate-y-0.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-3"
        >
          <path
            d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  /* Hamburger lines — need custom CSS for the animated transforms */
  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: currentColor;
    border-radius: 2px;
    transition:
      transform 0.35s cubic-bezier(0.77, 0, 0.175, 1),
      opacity 0.25s ease;
  }

  .hamburger-line-1 {
    transform: translateY(-4px);
  }

  .hamburger-line-3 {
    transform: translateY(4px);
  }

  .hamburger-active .hamburger-line-1 {
    transform: translateY(2px) rotate(45deg);
  }

  .hamburger-active .hamburger-line-2 {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger-active .hamburger-line-3 {
    transform: translateY(-2px) rotate(-45deg);
  }

  /* Mobile link staggered animation — needs CSS variable for delay */
  .mobile-menu-link {
    transition:
      opacity 0.3s ease var(--delay, 0s),
      transform 0.3s ease var(--delay, 0s),
      color 0.2s ease;
  }

  :global(.is-open) .mobile-menu-link {
    opacity: 1;
    transform: translateX(0);
  }

  /* Body scroll lock */
  :global(body.menu-open) {
    overflow: hidden;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const closeBtn = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");
    const backdrop = menu?.querySelector("div:first-child");

    if (!toggleBtn || !closeBtn || !menu) return;

    function openMenu() {
      menu!.classList.add("is-open");
      toggleBtn!.classList.add("hamburger-active");
      toggleBtn!.setAttribute("aria-expanded", "true");
      toggleBtn!.setAttribute("aria-label", "Cerrar menú de navegación");
      document.body.classList.add("menu-open");
    }

    function closeMenu() {
      menu!.classList.remove("is-open");
      toggleBtn!.classList.remove("hamburger-active");
      toggleBtn!.setAttribute("aria-expanded", "false");
      toggleBtn!.setAttribute("aria-label", "Abrir menú de navegación");
      document.body.classList.remove("menu-open");
    }

    toggleBtn.addEventListener("click", () => {
      const isOpen = menu!.classList.contains("is-open");
      isOpen ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu!.classList.contains("is-open")) {
        closeMenu();
        toggleBtn!.focus();
      }
    });

    // Close menu when a link is clicked
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>
