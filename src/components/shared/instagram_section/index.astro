---
import { site } from "../../../config";
---

<section
  class="max-w-7xl mx-auto py-24 md:py-32 text-center"
  aria-label="Redes sociales"
>
  <h2
    class="font-serif text-2xl md:text-7xl text-foreground"
    data-animate="fade-up"
  >
    Síguenos en
    <a
      href={site.instagram}
      target="_blank"
      rel="noopener noreferrer"
      class="hover:underline"
      aria-label="Visitar nuestro perfil de Instagram @egidajuridica"
      >@egidajuridica</a
    >
  </h2>
</section>
