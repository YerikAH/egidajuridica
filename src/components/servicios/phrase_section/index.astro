---
interface Props {
  backgroundText?: string;
  description?: string;
}

const {
  backgroundText = "SELLERS",
  description = "Selling your home is one of the most important financial decisions you can make. It can be a tough decision as it's likely you have an emotional investment in your home and selling involves a lot of moving parts. Contact us and we will show you how we can make your selling experience as seamless as possible.",
} = Astro.props;
---

<section
  class="relative w-full bg-white py-24 md:py-32 z-20 transition-all flex items-center justify-center overflow-hidden min-h-[50vh]"
  aria-label="Filosofía de Egida Jurídica"
>
  <!-- Giant Background Text Wrapper (Decorative) -->
  <div
    class="absolute inset-x-0 top-0 h-full overflow-hidden pointer-events-none select-none z-0"
    aria-hidden="true"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-[10%] w-full text-center flex justify-center bg-text-parallax"
    >
      <span
        class="text-[28vw] sm:text-[25vw] md:text-[22vw] lg:text-[20vw] xl:text-[22vw] font-serif text-[#F8F8F8] tracking-[0.2em] sm:tracking-[0.3em] uppercase opacity-80 whitespace-nowrap"
        style="font-family: 'Times New Roman', serif; line-height: 0.7;"
      >
        {backgroundText}
      </span>
    </div>
  </div>

  <!-- Content Layer -->
  <div
    class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full flex justify-center items-center"
  >
    <blockquote
      class="border-l border-gold/80 sm:border-l-2 sm:border-gold pl-6 md:pl-8 py-2 md:py-4 max-w-5xl"
      data-animate="slide-left"
      data-animate-duration="slow"
    >
      <p
        class="font-serif text-xl md:text-2xl lg:text-4xl tracking-wide text-zinc-800"
      >
        {description}
      </p>
    </blockquote>
  </div>
</section>
