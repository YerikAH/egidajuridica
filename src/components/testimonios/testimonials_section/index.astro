---

<section
  class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-16 lg:py-24 font-sans"
  aria-label="Testimonios de clientes de Egida Jurídica"
  id="main-content"
>
  <div
    class="space-y-4 md:space-y-6"
    role="list"
    aria-label="Lista de testimonios"
  >
    {
      testimonialsData.map((testimonial, index) => (
        <article
          class="border border-border/60 p-5 sm:p-6 md:p-8 lg:p-12 bg-background w-full testimonial-card-animate"
          role="listitem"
          aria-label={`Testimonio de ${testimonial.author}`}
        >
          <blockquote>
            <p class="text-muted-foreground text-sm md:text-base leading-relaxed mb-4 md:mb-6">
              {testimonial.quote}
            </p>
            <footer>
              <cite class="font-serif text-foreground text-lg md:text-xl font-medium tracking-wide not-italic">
                {testimonial.author}
              </cite>
            </footer>
          </blockquote>
        </article>
      ))
    }
  </div>
</section>
