---
import { Header, Footer } from "../components/shared";
import {
  HeroSection,
  AboutSection,
  ServicesSection,
} from "../components/principal";
import {
  TeamSection,
  SuccessStoriesSection,
  InstagramSection,
} from "../components/shared";
import { CoreLayout } from "../layouts";
import { principalMeta, routes } from "../config";
---

<CoreLayout
  title={principalMeta.title}
  description={principalMeta.description}
  keywords={principalMeta.keywords}
  canonical={principalMeta.canonical}
  type={principalMeta.type}
  robots={principalMeta.robots}
  structuredData={principalMeta.structuredData}
>
  <Header />
  <main id="main-content">
    <HeroSection />
    <AboutSection
      backgroundText="¿Qué hacemos?"
      title="Asesoramiento jurídico claro y eficaz"
      description="Prestamos servicios legales orientados a resolver conflictos, prevenir riesgos y acompañar a nuestros clientes en decisiones jurídicas relevantes. Nuestro enfoque combina conocimiento técnico, análisis estratégico y un trato directo y transparente."
      subtitle="¿Qué hacemos?"
      linkText="Conoce más sobre nosotros"
      linkHref={routes.about}
      imageSrc="https://images.pexels.com/photos/4427507/pexels-photo-4427507.jpeg"
      imageAlt="Equipo profesional de abogados trabajando en un caso"
    />
    <ServicesSection client:load />
    <TeamSection client:load />
    <SuccessStoriesSection client:load />
    <AboutSection
      backgroundText="Especialización"
      subtitle="Áreas de práctica"
      title="Enfocados en lo que mejor sabemos hacer"
      description="Nos especializamos en áreas clave del derecho para ofrecer un asesoramiento más preciso, eficaz y adaptado a cada caso. La especialización nos permite profundizar en cada materia y aportar soluciones jurídicas con mayor rigor y seguridad."
      linkText="Conoce nuestras áreas de práctica"
      linkHref={routes.services}
      imageSrc="https://images.pexels.com/photos/4427507/pexels-photo-4427507.jpeg"
      imageAlt="Documentos legales y libros de derecho"
      reverseLayout
    />
    <InstagramSection />
  </main>
  <Footer />
</CoreLayout>
