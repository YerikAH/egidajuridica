---
import TeamSection from "../../components/shared/team_section";
import ExpertiseSection from "../../components/acerca/expertise_section/index.astro";
import {
  AboutSection,
  SuccessStoriesSection,
} from "../../components/principal";
import { Footer, Header, HeroSection } from "../../components/shared";
import { CoreLayout } from "../../layouts";
import { aboutMeta } from "../../config";
---

<CoreLayout
  title={aboutMeta.title}
  description={aboutMeta.description}
  keywords={aboutMeta.keywords}
  canonical={aboutMeta.canonical}
  type={aboutMeta.type}
  robots={aboutMeta.robots}
  structuredData={aboutMeta.structuredData}
>
  <Header />
  <main id="main-content">
    <HeroSection
      title="Comprometidos con la defensa de tus derechos."
      description="En Egida Jurídica somos una firma legal orientada a ofrecer soluciones jurídicas sólidas, claras y eficaces. Nuestro trabajo se basa en el rigor profesional, la cercanía con el cliente y una estrategia legal adaptada a cada caso."
      buttons={[]}
      imageSrc="https://images.pexels.com/photos/8134189/pexels-photo-8134189.jpeg"
      imageAlt="Profesional jurídica consultando documentos legales"
    />
    <ExpertiseSection />
    <TeamSection client:load />
    <SuccessStoriesSection client:load />
    <AboutSection
      subtitle="Nuestra trayectoria"
      imageAlt="Escritorio profesional con documentos legales"
      imageSrc="https://images.pexels.com/photos/7781900/pexels-photo-7781900.jpeg"
      title="Una firma con recorrido"
      description="Con más de 20 años de experiencia en el ámbito jurídico, Egida Jurídica se ha consolidado como una firma comprometida con la excelencia profesional y la defensa de los intereses de sus clientes."
    />
  </main>
  <Footer />
</CoreLayout>
