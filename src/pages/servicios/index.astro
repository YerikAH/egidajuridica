---
import {
  AboutSection,
  ServicesSection,
  SuccessStoriesSection,
} from "../../components/principal";
import {
  Footer,
  Header,
  HeroSection,
  InstagramSection,
} from "../../components/shared";
import { CoreLayout } from "../../layouts";
import { PhraseSection, SpecialtiesSection } from "../../components/servicios";
import { routes, servicesMeta } from "../../config";
---

<CoreLayout
  title={servicesMeta.title}
  description={servicesMeta.description}
  keywords={servicesMeta.keywords}
  canonical={servicesMeta.canonical}
  type={servicesMeta.type}
  robots={servicesMeta.robots}
  structuredData={servicesMeta.structuredData}
>
  <Header />
  <main id="main-content">
    <HeroSection
      title="Asesoramiento jurídico especializado"
      description="Ofrecemos asesoramiento legal especializado en derecho laboral, civil y empresarial, con un enfoque profesional, estratégico y orientado a proteger los intereses de nuestros clientes."
      imageSrc="https://images.pexels.com/photos/8112166/pexels-photo-8112166.jpeg"
      imageAlt="Abogados especializados en consulta profesional"
      buttons={[
        {
          text: "Solicitar consulta",
          href: routes.contact,
        },
      ]}
    />
    <PhraseSection
      backgroundText="creemos"
      description="Creemos que un buen asesoramiento jurídico nace del conocimiento profundo de cada materia y del análisis riguroso de cada caso. Por eso trabajamos desde la especialización, ofreciendo soluciones legales claras, realistas y adaptadas a las necesidades concretas de cada cliente."
    />
    <SpecialtiesSection
      imageAlt="Profesionales del derecho en reunión de estrategia"
      imageSrc="https://images.pexels.com/photos/8112159/pexels-photo-8112159.jpeg"
      title="Expertos en las áreas clave del derecho"
      features={[
        {
          title: "Derecho Laboral",
          description:
            "Asesoramos y representamos en conflictos laborales, despidos, contratos y defensa de derechos tanto de trabajadores como de empresas.",
          linkText: "Contactar",
          linkHref: routes.contact,
        },
        {
          title: "Derecho Empresarial",
          description:
            "Acompañamos a empresas y profesionales en la toma de decisiones jurídicas, la prevención de riesgos legales y la resolución de conflictos mercantiles.",
          linkText: "Contactar",
          linkHref: routes.contact,
        },
        {
          title: "Derecho Civil",
          description:
            "Ofrecemos asesoramiento en contratos, reclamaciones, responsabilidad civil y otras cuestiones jurídicas de ámbito personal y patrimonial.",
          linkText: "Contactar",
          linkHref: routes.contact,
        },
      ]}
    />
    <ServicesSection client:load />
    <AboutSection
      imageAlt="Balanza de la justicia representando el rigor jurídico"
      imageSrc="https://images.pexels.com/photos/6077476/pexels-photo-6077476.jpeg"
      subtitle="Nuestro enfoque"
      backgroundText="enfoque"
      title="Experiencia y criterio"
      description="Combinamos años de ejercicio profesional con un enfoque riguroso y personalizado. Cada asunto se aborda con atención, estrategia y una comunicación clara, garantizando un acompañamiento constante durante todo el proceso legal."
    />
    <SuccessStoriesSection client:load />
    <InstagramSection />
  </main>
  <Footer />
</CoreLayout>
